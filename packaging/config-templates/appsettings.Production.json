{
  "_comment": "This file is generated by the installer from .epcfg values. Do not edit manually.",
  "Installer": {
    "DataRoot": "${epcfg:data_root}",
    "SiteConfigPath": "${epcfg:config_path}"
  },
  "Services": {
    "MySql": { "Port": "${epcfg:services.mysql_port}" },
    "Cache": { "Port": "${epcfg:services.cache_port}" },
    "Eventing": { "Port": "${epcfg:services.eventing_port}" },
    "Web": { "HttpsPort": "${epcfg:services.web_https_port}" }
  },
  "Monitoring": {
    "HealthPollIntervalSeconds": "${epcfg:monitoring.health_poll_interval_seconds}",
    "DiskCheckIntervalSeconds": "${epcfg:monitoring.disk_check_interval_seconds}",
    "DriftCheckIntervalSeconds": "${epcfg:monitoring.drift_check_interval_seconds}"
  },
  "Backup": {
    "Targets": "${epcfg:backup_targets}",
    "Schedule": {
      "Daily": "${epcfg:backup_schedule.daily}",
      "WeeklyDay": "${epcfg:backup_schedule.weekly_day}",
      "WeeklyTime": "${epcfg:backup_schedule.weekly_time}"
    }
  },
  "LogRotation": {
    "ApplicationRetentionDays": "${epcfg:log_retention_days.application}",
    "AuditRetentionDays": "${epcfg:log_retention_days.audit}",
    "MySqlRetentionDays": "${epcfg:log_retention_days.mysql}"
  },
  "Observability": {
    "ApplicationName": "epacs-installer-agent",
    "Environment": "Production"
  }
}
