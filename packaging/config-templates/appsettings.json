{
  "Installer": {
    "DataRoot": "D:\\ePACSData",
    "BinaryRoot": "C:\\Program Files\\ePACS",
    "TempRoot": null,
    "StateFile": null,
    "ServiceMapPath": "config/service-map.yaml",
    "ManifestPath": "release-manifest.yaml",
    "SiteConfigPath": null
  },
  "Precheck": {
    "MinOsBuild": 17763,
    "MinRamGb": 8,
    "RecommendedRamGb": 16,
    "MinDataDiskFreeGb": 100,
    "MinSystemDiskFreeGb": 10,
    "RequiredPorts": [3306, 6379, 9092, 443],
    "BlockOnMissingAvExclusions": false,
    "BlockOnPendingReboot": false,
    "AvExclusionPaths": []
  },
  "Services": {
    "MySql": {
      "Port": 3306,
      "DataDir": "${DataRoot}\\mysql\\data",
      "LogDir": "${DataRoot}\\mysql\\logs",
      "MaxConnections": 50,
      "ServiceAccount": "ePACSDbSvc"
    },
    "Cache": {
      "Port": 6379,
      "DataDir": "${DataRoot}\\cache",
      "MaxMemoryMb": 512,
      "ServiceAccount": "ePACSCacheSvc"
    },
    "Eventing": {
      "Port": 9092,
      "DataDir": "${DataRoot}\\eventing\\data",
      "LogDir": "${DataRoot}\\eventing\\logs",
      "HeapSizeMb": 512,
      "ServiceAccount": "ePACSEventSvc",
      "PreCreateTopics": [
        "epacs.local.sync-ready",
        "epacs.local.dead-letter",
        "epacs.local.commands"
      ]
    },
    "Web": {
      "HttpsPort": 443,
      "ServiceAccount": "ePACSAppSvc"
    },
    "Sync": {
      "HealthPort": 5080,
      "ServiceAccount": "ePACSSyncSvc",
      "ChunkSizeBytes": 1048576,
      "MaxRetryAttempts": 10,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerHalfOpenSeconds": 300
    },
    "Agent": {
      "HealthPort": 5090
    }
  },
  "Monitoring": {
    "HealthPollIntervalSeconds": 60,
    "DiskCheckIntervalSeconds": 900,
    "DriftCheckIntervalSeconds": 3600,
    "CertExpiryCheckIntervalSeconds": 21600,
    "ClockDriftCheckIntervalSeconds": 1800,
    "DiskThresholds": {
      "YellowPercent": 20,
      "RedPercent": 10,
      "CriticalPercent": 5
    },
    "ClockDriftThresholds": {
      "WarnSeconds": 30,
      "BlockSyncSeconds": 300
    },
    "HealthFailureThresholds": {
      "RestartAfterConsecutiveFailures": 3,
      "SupportBundleAfterConsecutiveFailures": 5
    },
    "CertExpiryWarningDays": [60, 30, 7]
  },
  "Backup": {
    "Targets": ["${DataRoot}\\backups"],
    "Schedule": {
      "Daily": "02:00",
      "WeeklyDay": "Sunday",
      "WeeklyTime": "03:00"
    },
    "Retention": {
      "DailyCount": 7,
      "WeeklyCount": 4,
      "PreUpgradeCount": 2
    },
    "Encryption": {
      "Algorithm": "AES-256-GCM",
      "CertificateThumbprint": null
    },
    "LargeDbThresholdGb": 5,
    "TargetFreeSpaceMultiplier": 1.5,
    "WarnOnSameVolume": true
  },
  "LogRotation": {
    "ApplicationRetentionDays": 30,
    "AuditRetentionDays": 90,
    "MySqlRetentionDays": 7,
    "CompressAfterDays": 7,
    "MaxLogVolumePercent": 10,
    "MaxLogVolumeGb": 50,
    "RotationTime": "02:00"
  },
  "Observability": {
    "ApplicationName": "epacs-installer-agent",
    "ModuleName": "Installer",
    "Environment": "Production",
    "Sinks": {
      "Console": { "Enabled": false },
      "File": {
        "Enabled": true,
        "Path": "${DataRoot}\\logs\\installer\\installer-.json",
        "RollingInterval": "Day",
        "RetainedFileCountLimit": 30,
        "FileSizeLimitBytes": 104857600
      },
      "Elasticsearch": { "Enabled": false, "Url": null }
    },
    "Masking": { "Enabled": true },
    "AuditHook": { "Mode": "TraceabilityBridge" }
  },
  "ErrorHandling": {
    "ReturnProblemDetails": true,
    "CatalogFiles": [
      "config/error-catalog/core.yaml",
      "config/error-catalog/installer.yaml"
    ],
    "ClientErrorUriBase": "https://errors.epacs.in/",
    "SuppressStackTraceInProduction": true
  },
  "FileSync": {
    "Enabled": false,
    "ScanIntervalSeconds": 300,
    "MaxUploadBatchSizeMb": 50,
    "Transport": {
      "Primary": "HTTPS",
      "Fallback": "SFTP",
      "Https": {
        "Endpoint": "https://nldr.epacs.gov.in/api/v1.0/files",
        "ChunkSizeBytes": 1048576,
        "TimeoutSeconds": 120
      },
      "Sftp": {
        "Host": "sftp.nldr.epacs.gov.in",
        "Port": 22,
        "Username": "",
        "KeyPath": "${DataRoot}\\keys\\sftp_key",
        "RemotePath": "/"
      }
    },
    "Deduplication": {
      "Algorithm": "SHA-256",
      "SkipIfHashUnchanged": true
    },
    "Inbound": {
      "Enabled": false,
      "PollIntervalSeconds": 600
    },
    "MaxHashFileSizeMbDuringPeakHours": 50,
    "PeakHoursStart": "09:00",
    "PeakHoursEnd": "18:00"
  },
  "Heartbeat": {
    "Enabled": true,
    "IntervalSeconds": 300,
    "Transport": "HTTPS",
    "Https": {
      "Endpoint": "https://dashboard.coopsindia.gov.in/api/v1.0/pacsStatus",
      "TimeoutSeconds": 10,
      "RetryCount": 3
    },
    "WebSocket": {
      "Endpoint": "wss://dashboard.coopsindia.gov.in/ws/v1.0/pacsStatus",
      "ReconnectIntervalSeconds": 30
    },
    "Payload": {
      "IncludeDiskUsage": true,
      "IncludeSyncStatus": true,
      "IncludeHealthStatus": true,
      "IncludeFilesSyncStatus": true
    },
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerCooldownSeconds": 300
  }
}
