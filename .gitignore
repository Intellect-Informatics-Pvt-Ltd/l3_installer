# ═══════════════════════════════════════════════════════════════════════════════
# .gitignore — ePACS Offline Installer + Sync Test Harness
# ═══════════════════════════════════════════════════════════════════════════════

# ─── .NET Build Output ────────────────────────────────────────────────────────
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Ll]og/
[Ll]ogs/

# ─── Visual Studio / Rider / VS Code ─────────────────────────────────────────
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
[Tt]est[Rr]esult*/
[Dd]ebugPublic/
[Rr]eleases/
[Aa]rtifacts/
*.pidb
*.svclog
*.scc

# ─── NuGet ────────────────────────────────────────────────────────────────────
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json

# ─── Publish Output ───────────────────────────────────────────────────────────
publish/
harness/publish/

# ─── User Secrets ─────────────────────────────────────────────────────────────
secrets.json

# ─── JetBrains Rider ──────────────────────────────────────────────────────────
.idea/
*.sln.iml

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ─── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Temporary / Swap ─────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*~
*.log

# ─── Test Results ─────────────────────────────────────────────────────────────
TestResults/
coverage/
*.coverage
*.coveragexml
*.trx

# ─── Docker volumes (local dev) ──────────────────────────────────────────────
harness/docker/volumes/

# ─── Evidence folders (generated during test runs) ────────────────────────────
Evidence/

# ─── Kiro specs (keep tracked — these are design docs) ────────────────────────
# .kiro/ is tracked intentionally

# ─── Qoder plans ──────────────────────────────────────────────────────────────
.qoder/

# ─── Miscellaneous ────────────────────────────────────────────────────────────
*.cache
*.pidb
*.pdb
*.dll
*.exe
!harness/scripts/*.ps1
