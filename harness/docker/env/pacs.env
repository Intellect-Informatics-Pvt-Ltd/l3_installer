# PACS-side environment variables for Docker Compose.
# Do NOT store real secrets here; use a secrets manager in production.

MYSQL_ROOT_PASSWORD=root

# .NET configuration overrides (ASPNETCORE_ prefix maps to appsettings)
ConnectionStrings__PacsDb=Server=pacs-mysql;Port=3306;Database=epacs_pacs;User=root;Password=root;SslMode=None;AllowUserVariables=true
ConnectionStrings__PacsRedis=pacs-redis:6379,abortConnect=false

Pacs__PacsId=PACS-AP-0001
Pacs__Tenant=ePACS
Pacs__DataRoot=/app/data

Harness__TestMode=true
Harness__Profile=Default
Harness__ScenarioPlayerEnabled=true

Sync__Outbound__BootstrapServers=kafka:9092
Messaging__Kafka__BootstrapServers=kafka:9092
Sync__NldrIngestUrl=http://nldr-api:8080/api/sync/ingest
