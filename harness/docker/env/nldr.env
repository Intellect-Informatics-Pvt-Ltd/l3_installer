# NLDR-side environment variables for Docker Compose.

MYSQL_ROOT_PASSWORD=root

ConnectionStrings__NldrDb=Server=nldr-mysql;Port=3306;Database=epacs_nldr;User=root;Password=root;SslMode=None;AllowUserVariables=true
ConnectionStrings__NldrRedis=nldr-redis:6379,abortConnect=false

Nldr__Tenant=ePACS
Nldr__DataRoot=/app/data

Harness__TestMode=true
Harness__Profile=Default

Messaging__Kafka__BootstrapServers=kafka:9092
