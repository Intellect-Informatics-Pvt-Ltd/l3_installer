{
  "ConnectionStrings": {
    "NldrDb": "Server=localhost;Port=3308;Database=epacs_nldr;User=root;Password=root;SslMode=None;AllowUserVariables=true",
    "NldrRedis": "localhost:6381,abortConnect=false"
  },
  "Nldr": {
    "Tenant": "ePACS",
    "DataRoot": "${LOCALAPPDATA}/ePACS-Harness",
    "Iam": { "Enabled": false }
  },
  "Harness": {
    "TestMode": true,
    "Profile": "Default"
  },
  "Sync": {
    "AcksTopic":      "epacs.nldr.acks",
    "CommandsTopic":  "epacs.nldr.commands",
    "DeadletterTopic":"epacs.deadletter",
    "ClockDrift": { "MaxAllowedSeconds": 30, "BlockingSeconds": 300 }
  },
  "Messaging": {
    "Kafka": { "BootstrapServers": "localhost:9092" }
  },
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*"
}
