{
  "Pacs": {
    "PacsId": "PACS-AP-0001",
    "DataRoot": "D:\\ePACSData",
    "Tenant": "AP"
  },

  "Harness": {
    "TestMode": false,
    "Profile": "Installer"
  },

  "ConnectionStrings": {
    "PacsDb": "Server=127.0.0.1;Port=3306;Database=epacs_pacs;User=epacs_app;Password=${PACS_DB_PASSWORD};SslMode=None;AllowPublicKeyRetrieval=true;ConnectionTimeout=10;DefaultCommandTimeout=30",
    "NldrDb": "Server=127.0.0.1;Port=3306;Database=epacs_nldr;User=epacs_app;Password=${NLDR_DB_PASSWORD};SslMode=None;AllowPublicKeyRetrieval=true;ConnectionTimeout=10;DefaultCommandTimeout=30",
    "PacsRedis": "127.0.0.1:6379,abortConnect=false,connectTimeout=5000,syncTimeout=3000",
    "NldrRedis": "127.0.0.1:6379,abortConnect=false,connectTimeout=5000,syncTimeout=3000,defaultDatabase=1"
  },

  "Messaging": {
    "Kafka": {
      "BootstrapServers": "127.0.0.1:9092",
      "SecurityProtocol": "Plaintext"
    }
  },

  "Sync": {
    "Outbox": {
      "PollIntervalMs": 500,
      "BatchSize": 50,
      "ProcessingLockTimeoutSeconds": 120
    },
    "Retry": {
      "MaxAttempts": 7,
      "BaseDelayMs": 2000,
      "MaxDelayMs": 60000,
      "JitterFactor": 0.2
    },
    "Circuit": {
      "FailureThreshold": 5,
      "OpenDurationSeconds": 60,
      "HalfOpenProbeCount": 1
    },
    "Heartbeat": {
      "IntervalSeconds": 30
    },
    "File": {
      "ChunkSizeBytes": 262144,
      "MaxConcurrentChunks": 4,
      "StagingPath": "D:\\ePACSData\\files\\staging",
      "QueuePath": "D:\\ePACSData\\files\\queue",
      "MaxFileSizeMb": 50
    },
    "OutboundTopic": "epacs.pacs.outbound",
    "AckTopic": "epacs.nldr.acks",
    "CommandTopic": "epacs.nldr.commands",
    "HeartbeatTopic": "epacs.pacs.heartbeat",
    "DeadLetterTopic": "epacs.deadletter"
  },

  "Nldr": {
    "IngestUrl": "http://nldr-central.epacs.gov.in/api/sync/ingest",
    "FileUploadUrl": "http://nldr-central.epacs.gov.in/api/files"
  },

  "Observability": {
    "ApplicationName": "epacs-harness",
    "ModuleName": "Harness",
    "Environment": "Production",
    "Sinks": {
      "Console": { "Enabled": false },
      "File": {
        "Enabled": true,
        "Path": "D:\\ePACSData\\logs\\harness\\harness-.json",
        "RollingInterval": "Day",
        "RetainedFileCountLimit": 30,
        "FileSizeLimitBytes": 104857600
      }
    }
  },

  "ErrorHandling": {
    "CatalogFiles": [
      "config/error-catalog/harness.yaml"
    ],
    "SuppressStackTraceInProduction": true
  }
}
