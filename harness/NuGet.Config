<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      Primary: public NuGet.org feed.
      For offline / pilot deployments, replace with the local package cache
      bundled in the installer payload at %DataRoot%\packages\nuget.
    -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Internal Intellect NuGet feed (optional – uncomment and replace URL when
      the internal Intellect.Erp.* packages are available).
    -->
    <!-- <add key="intellect-internal" value="https://pkgs.intellect.in/nuget/v3/index.json" /> -->
  </packageSources>

  <!-- Package source mapping required by central package management (NU1507) -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
